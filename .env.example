# Supabase client values for a future Vite integration.
# These are public anon/project values, not service-role secrets.
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only values for future API routes, edge functions, or backend services.
# Do not expose these in client-side code.
STRIPE_SECRET_KEY=your_stripe_secret_key
OPENAI_API_KEY=your_openai_api_key

